# .env.example
# Copy this file to .env and fill in your actual values

# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/project_smartchat

# JWT Security (must be at least 32 characters)
SECRET_KEY=your_super_secret_key_at_least_32_chars_long_enough

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth (optional, can be empty)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email configuration for password reset
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=khulapeshital7030@gmail.com
SMTP_PASSWORD=quogtihbuapxblf
PASSWORD_RESET_EXPIRE_MINUTES=10

# Frontend configuration
FRONTEND_URL=http://localhost:3000

# CORS configuration (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=true